)
res_index$Diversity <- res_diversity$Diversity
res_index$sumMut_norm <- (res_index$sumMut - min(res_index$sumMut)) /
(max(res_index$sumMut) - min(res_index$sumMut))
res_index$GiniTau_norm <- (res_index$GiniTau - min(res_index$GiniTau)) /
(max(res_index$GiniTau) - min(res_index$GiniTau))
res_index$scMutScoreQun <- res_index$sumMut_norm
res_index$scMutScore <- scales::rescale(res_index$scMutScore, to = c(0, 1))
res_index$scMutScoreQun <- scales::rescale(res_index$scMutScoreQun, to = c(0, 1))
res <- list(diversity = res_diversity, score = res_index, matrixD = data_cell_time_matrix)
return(res)
}
res_index <- cal_scMutScore(mgatk_cellMutation, mgatk_mutationTime_nor)
