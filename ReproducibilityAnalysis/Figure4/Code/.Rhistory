data_value_similarity_RNA <- list(DXMy_RELLy = vals_RelCLP_DxGMP_RNA,
DXLy_RELLy = vals_DxCLP_RelCLP_RNA,
DXMy_DXLy = vals_DxCLP_DxGMP_RNA,
RELMy_RELLy = vals_RelCLP_RelGMP_RNA,
DXHSC_RELLy = vals_RelCLP_DxHSC_RNA,
RELHSC_RELLy = vals_RelCLP_RelHSC_RNA,
DXProg_RELLy = vals_RelCLP_DxProg_RNA,
RELProg_RELLy = vals_RelCLP_RelProg_RNA)
data_value_similarity_ATA <- list(DXMy_RELLy = vals_RelCLP_DxGMP_ATA,
DXLy_RELLy = vals_DxCLP_RelCLP_ATA,
DXMy_DXLy = vals_DxCLP_DxGMP_ATA,
RELMy_RELLy = vals_RelCLP_RelGMP_ATA,
DXHSC_RELLy = vals_RelCLP_DxHSC_ATA,
RELHSC_RELLy = vals_RelCLP_RelHSC_ATA,
DXProg_RELLy = vals_RelCLP_DxProg_ATA,
RELProg_RELLy = vals_RelCLP_RelProg_ATA)
comparisons <- list(
c("DXMy_RELLy", "DXLy_RELLy"),
c("DXMy_RELLy", "DXMy_DXLy"),
c("DXMy_RELLy", "RELMy_RELLy"),
c("DXMy_RELLy", "DXHSC_RELLy"),
c("DXMy_RELLy", "RELHSC_RELLy"),
c("DXMy_RELLy", "DXProg_RELLy"),
c("DXMy_RELLy", "RELProg_RELLy")
)
p_boxPlotdata_value_similarity_RNA <- ggplot(stack(data_value_similarity_RNA), aes(ind, values, fill = ind)) +
geom_boxplot() +
stat_compare_means(comparisons = comparisons, method = "wilcox.test") +
theme_classic()
p_boxPlotdata_value_similarity_ATA <- ggplot(stack(data_value_similarity_ATA), aes(ind, values, fill = ind)) +
geom_boxplot() +
stat_compare_means(comparisons = comparisons, method = "wilcox.test") +
theme_classic()
