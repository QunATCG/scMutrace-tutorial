data_census_fraction[i, "LT_S79_cancer"]    <- length(intersect(cells_LT_S79_cancer, cells_TH179)) / length(cells_LT_S79_cancer)
data_census_fraction[i, "LT_S79_noncancer"] <- length(intersect(cells_LT_S79_noncancer, cells_TH179)) / length(cells_LT_S79_noncancer)
data_census_fraction[i, "LT_S80_cancer"]    <- length(intersect(cells_LT_S80_cancer, cells_TH179)) / length(cells_LT_S80_cancer)
data_census_fraction[i, "LT_S80_noncancer"] <- length(intersect(cells_LT_S80_noncancer, cells_TH179)) / length(cells_LT_S80_noncancer)
}
# TH248
if (gene %in% genes_TH248) {
sites_TH248 <- data_SSM_TH248_ann_selected[data_SSM_TH248_ann_selected$Gene.refGene == gene, "Mutation"]
cells_TH248 <- retriveCellsByLocation(data_CSM_TH248, sites_TH248)$Mut
data_census_fraction[i, "LT_S69_cancer"]    <- length(intersect(cells_LT_S69_cancer, cells_TH248)) / length(cells_LT_S69_cancer)
data_census_fraction[i, "LT_S69_noncancer"] <- length(intersect(cells_LT_S69_noncancer, cells_TH248)) / length(cells_LT_S69_noncancer)
data_census_fraction[i, "LT_S74_cancer"]    <- length(intersect(cells_LT_S74_cancer, cells_TH248)) / length(cells_LT_S74_cancer)
data_census_fraction[i, "LT_S74_noncancer"] <- length(intersect(cells_LT_S74_noncancer, cells_TH248)) / length(cells_LT_S74_noncancer)
}
# TH179_NAT
if (gene %in% genes_TH179NAT) {
sites_TH179NAT <- data_SSM_TH179NAT_ann_selected[data_SSM_TH179NAT_ann_selected$Gene.refGene == gene, "Mutation"]
cells_TH179NAT <- retriveCellsByLocation(data_CSM_TH179NAT, sites_TH179NAT)$Mut
data_census_fraction[i, "TH179_NAT"] <- length(intersect(cells_TH179_NAT_normal, cells_TH179NAT)) / length(cells_TH179_NAT_normal)
}
}
max_val <- max(data_census_fraction)
col_fun_v1 <- colorRamp2(c(0, max_val * 0.33, max_val * 0.66, max_val), c("#404040", "#bababa", "#f4a582", "#ca0020"))
p_proportion <- pheatmap(data_census_fraction,
cluster_rows = FALSE,
cluster_cols = FALSE,
cellwidth = 20,
cellheight = 20,
display_numbers = TRUE,
number_color = "white",
border_color = "white",
color = col_fun_v1)
p_proportion
pdf("../Figures/SMARTSeq/p_proportion_cellType.pdf", width = 8.21, height = 5.04)
p_proportion
dev.off()
# from COSMIC database
# TP53 from original paper
data_cencusgenes <- c("AKT1", "ALK", "BAP1", "BRAF", "CCDC6", "CD74", "DDR2",
"DROSHA", "EGFR", "EML4", "ERBB2", "ERBB4", "EZR",
"FGFR2", "GOLPH3", "HIP1", "KDR", "KEAP1", "KIF5B",
"LRIG3", "MAP2K1", "MAP2K2", "NFE2L2", "NKX2-1",
"NRG1", "PIK3CB", "PTPN13", "RET", "ROS1", "SDC4",
"SMARCA4", "SOX2", "STK11", "TFG", "TPM3", "TPR", "TP53")
data_SSM_TH179_ann_selected <- data_SSM_TH179_ann[data_SSM_TH179_ann$Gene.refGene %in% data_cencusgenes & data_SSM_TH179_ann$Func.refGene %in% c("splicing", "exonic"),]
data_SSM_TH179NAT_ann_selected <- data_SSM_TH179NAT_ann[data_SSM_TH179NAT_ann$Gene.refGene %in% data_cencusgenes & data_SSM_TH179NAT_ann$Func.refGene %in% c("splicing", "exonic"),]
data_SSM_TH248_ann_selected <- data_SSM_TH248_ann[data_SSM_TH248_ann$Gene.refGene %in% data_cencusgenes & data_SSM_TH248_ann$Func.refGene %in% c("splicing", "exonic"),]
census_genes <- unique(c(data_SSM_TH179_ann_selected$Gene.refGene, data_SSM_TH248_ann_selected$Gene.refGene, data_SSM_TH179NAT_ann_selected$Gene.refGene))
# TH179
cells_LT_S58 <- data_meta[data_meta$sample_name == "LT_S58",]$CellTag
cells_LT_S79 <- data_meta[data_meta$sample_name == "LT_S79",]$CellTag
cells_LT_S80 <- data_meta[data_meta$sample_name == "LT_S80",]$CellTag
# TH248
cells_LT_S69 <- data_meta[data_meta$sample_name == "LT_S69",]$CellTag
cells_LT_S74 <- data_meta[data_meta$sample_name == "LT_S74",]$CellTag
# TH249NAT
cells_TH179_NAT_normal <- data_meta[data_meta$patient_id == "TH179_NAT",]$CellTag
col_fra <- c("S74_GATK", "S69_GATK",
"S58_GATK", "S79_GATK",
"S80_GATK", "NAT_GATK",
"S74", "S69",
"S58", "S79",
"S80", "NAT")
data_census_fraction_sample <- as.data.frame(matrix(data = 0, nrow = length(census_genes), ncol = length(col_fra)))
rownames(data_census_fraction_sample) <- census_genes
colnames(data_census_fraction_sample) <- col_fra
genes_TH179 <- unique(data_SSM_TH179_ann_selected$Gene.refGene)
genes_TH179NAT <- unique(data_SSM_TH179NAT_ann_selected$Gene.refGene)
genes_TH248 <- unique(data_SSM_TH248_ann_selected$Gene.refGene)
for (i in seq_along(census_genes)) {
gene <- census_genes[i]
# TH179
if (gene %in% genes_TH179) {
sites_TH179 <- data_SSM_TH179_ann_selected[data_SSM_TH179_ann_selected$Gene.refGene == gene, "Mutation"]
cells_TH179 <- retriveCellsByLocation(data_CSM_TH179, sites_TH179)$Mut
cells_TH179_GATK <- data_benchmarking_meta %>% filter(Type == "smartSeq" & patient_id == "TH179" & Gene == gene) %>% pull(CellTag)
data_census_fraction_sample[i, "S58"]    <- length(intersect(cells_LT_S58, cells_TH179)) / length(cells_LT_S58)
data_census_fraction_sample[i, "S79"]    <- length(intersect(cells_LT_S79, cells_TH179)) / length(cells_LT_S79)
data_census_fraction_sample[i, "S80"]    <- length(intersect(cells_LT_S80, cells_TH179)) / length(cells_LT_S80)
if (length(cells_TH179_GATK) > 0){
data_census_fraction_sample[i, "S58_GATK"]    <- length(intersect(cells_LT_S58, cells_TH179_GATK)) / length(cells_LT_S58)
data_census_fraction_sample[i, "S79_GATK"]    <- length(intersect(cells_LT_S79, cells_TH179_GATK)) / length(cells_LT_S79)
data_census_fraction_sample[i, "S80_GATK"]    <- length(intersect(cells_LT_S80, cells_TH179_GATK)) / length(cells_LT_S80)
}
}
# TH248
if (gene %in% genes_TH248) {
sites_TH248 <- data_SSM_TH248_ann_selected[data_SSM_TH248_ann_selected$Gene.refGene == gene, "Mutation"]
cells_TH248 <- retriveCellsByLocation(data_CSM_TH248, sites_TH248)$Mut
cells_TH248_GATK <- data_benchmarking_meta %>% filter(Type == "smartSeq" & patient_id == "TH248" & Gene == gene) %>% pull(CellTag)
data_census_fraction_sample[i, "S69"]    <- length(intersect(cells_LT_S69, cells_TH248)) / length(cells_LT_S69)
data_census_fraction_sample[i, "S74"]    <- length(intersect(cells_LT_S74, cells_TH248)) / length(cells_LT_S74)
if (length(cells_TH248_GATK) > 0){
data_census_fraction_sample[i, "S69_GATK"]    <- length(intersect(cells_LT_S69, cells_TH248_GATK)) / length(cells_LT_S69)
data_census_fraction_sample[i, "S74_GATK"]    <- length(intersect(cells_LT_S74, cells_TH248_GATK)) / length(cells_LT_S74)
}
}
# TH179_NAT
if (gene %in% genes_TH179NAT) {
sites_TH179NAT <- data_SSM_TH179NAT_ann_selected[data_SSM_TH179NAT_ann_selected$Gene.refGene == gene, "Mutation"]
cells_TH179NAT <- retriveCellsByLocation(data_CSM_TH179NAT, sites_TH179NAT)$Mut
data_census_fraction_sample[i, "NAT"] <- length(intersect(cells_TH179_NAT_normal, cells_TH179NAT)) / length(cells_TH179_NAT_normal)
}
}
max_val <- max(data_census_fraction_sample)
col_fun_v1 <- colorRamp2(c(0, max_val * 0.33, max_val * 0.66, max_val), c("#404040", "#bababa", "#f4a582", "#ca0020"))
p_proportion_sample <- pheatmap(data_census_fraction_sample,
cluster_rows = FALSE,
cluster_cols = FALSE,
cellwidth = 20,
cellheight = 20,
display_numbers = TRUE,
number_color = "white",
border_color = "white",
color = col_fun_v1)
p_proportion_sample
pdf("../Figures/SMARTSeq/p_proportion_sample.pdf", width = 8.21, height = 5.04)
p_proportion_sample
dev.off()
write.csv(data_census_fraction_sample, "../Data/SMARTSeq/Mutation_sample.csv")
